#!/bin/bash
#
# safe-swap.sh - Safely manage swap (off / on / flush)
#
# Usage:
#   sudo ./safe-swap.sh off              # swapoff with memory safety checks
#   sudo ./safe-swap.sh on               # swapon
#   sudo ./safe-swap.sh status           # show current memory/swap state
#   sudo ./safe-swap.sh flush            # swapoff -> sleep 5s -> swapon
#   sudo ./safe-swap.sh flush --sleep 30 # swapoff -> sleep 30s -> swapon
#
set -euo pipefail

# --- Config ---
SAFETY_RATIO=85           # max swap_used/available % before refusing
DEFAULT_FLUSH_SLEEP=5     # default sleep for flush mode (seconds)

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info()  { echo -e "${GREEN}[INFO]${NC}  $*"; }
log_warn()  { echo -e "${YELLOW}[WARN]${NC}  $*"; }
log_error() { echo -e "${RED}[ERROR]${NC} $*"; }

# --- Root check ---
check_root() {
    if [[ $EUID -ne 0 ]]; then
        log_error "This script requires root privileges. Please run with sudo."
        exit 1
    fi
}

# --- Memory info (MB) ---
get_mem_info() {
    mem_available=$(awk '/MemAvailable/ {printf "%d", $2/1024}' /proc/meminfo)
    swap_total=$(awk '/SwapTotal/     {printf "%d", $2/1024}' /proc/meminfo)
    swap_used=$((swap_total - $(awk '/SwapFree/ {printf "%d", $2/1024}' /proc/meminfo)))
}

# --- Status ---
show_status() {
    get_mem_info
    echo ""
    echo -e "${CYAN}=== Memory / Swap Status ===${NC}"
    free -m
    echo ""
    echo -e "  Available Memory : ${GREEN}${mem_available} MB${NC}"
    echo -e "  Swap Used        : ${YELLOW}${swap_used} MB${NC}"
    echo -e "  Swap Total       : ${swap_total} MB"

    if [[ $swap_total -gt 0 ]]; then
        local swap_devices
        swap_devices=$(swapon --show --noheadings 2>/dev/null || true)
        if [[ -n "$swap_devices" ]]; then
            echo ""
            echo -e "${CYAN}--- Active Swap Devices ---${NC}"
            swapon --show
        else
            echo -e "  Swap Status      : ${YELLOW}OFF (no active devices)${NC}"
        fi
    fi
    echo ""
}

# --- Pre-flight memory safety check ---
# Returns 0 = proceed with swapoff, 1 = already off (skip)
preflight_check() {
    get_mem_info

    if [[ $swap_used -eq 0 ]]; then
        if ! swapon --show --noheadings 2>/dev/null | grep -q .; then
            log_info "Swap is already off and unused. Nothing to do."
            return 1
        fi
        log_info "Swap is unused (0 MB). Disabling swap devices..."
        return 0
    fi

    show_status

    # Hard limit: available must exceed swap used
    if [[ $mem_available -le $swap_used ]]; then
        log_error "Available memory (${mem_available} MB) <= swap used (${swap_used} MB)."
        log_error "Aborting to prevent OOM. Free up memory or kill processes first."
        exit 1
    fi

    # Soft limit: warn if ratio is high
    local usage_pct=$(( swap_used * 100 / mem_available ))
    if [[ $usage_pct -ge $SAFETY_RATIO ]]; then
        log_warn "Swap usage is ${usage_pct}% of available memory (threshold: ${SAFETY_RATIO}%)."
        log_warn "Memory may become tight during swapoff."
        read -r -p "$(echo -e "${YELLOW}Continue? [y/N]: ${NC}")" confirm
        if [[ ! "$confirm" =~ ^[yY]$ ]]; then
            log_info "Aborted by user."
            exit 0
        fi
    fi

    local margin=$(( mem_available - swap_used ))
    log_info "Swap used: ${swap_used} MB / Available: ${mem_available} MB (headroom: ${margin} MB)"
    return 0
}

# --- swapoff with progress ---
do_swapoff() {
    if ! preflight_check; then
        return 0
    fi

    log_info "Running swapoff -a ..."

    swapoff -a &
    local swapoff_pid=$!

    while kill -0 "$swapoff_pid" 2>/dev/null; do
        get_mem_info
        if [[ $swap_used -gt 0 ]]; then
            printf "\r  Swap remaining: %5d MB  |  Available: %5d MB" "$swap_used" "$mem_available"
        fi
        sleep 1
    done

    wait "$swapoff_pid"
    local exit_code=$?
    echo ""

    if [[ $exit_code -eq 0 ]]; then
        log_info "swapoff completed successfully."
        free -m | grep -i swap
    else
        log_error "swapoff failed (exit code: ${exit_code})."
        log_warn "Recovering with swapon -a ..."
        swapon -a
        exit 1
    fi
}

# --- swapon ---
do_swapon() {
    if swapon --show --noheadings 2>/dev/null | grep -q .; then
        log_info "Swap is already active:"
        swapon --show
        return 0
    fi

    log_info "Running swapon -a ..."
    swapon -a

    if swapon --show --noheadings 2>/dev/null | grep -q .; then
        log_info "swapon completed successfully."
        swapon --show
    else
        log_warn "No swap devices found. Check /etc/fstab."
    fi
}

# --- flush: swapoff -> sleep -> swapon ---
do_flush() {
    local sleep_sec="${1:-$DEFAULT_FLUSH_SLEEP}"

    if ! [[ "$sleep_sec" =~ ^[0-9]+$ ]] || [[ "$sleep_sec" -lt 0 ]]; then
        log_error "Invalid sleep duration: ${sleep_sec}. Must be a non-negative integer."
        exit 1
    fi

    log_info "=== Flush mode: swapoff -> sleep ${sleep_sec}s -> swapon ==="
    echo ""

    # Step 1: swapoff
    log_info "[1/3] Disabling swap..."
    do_swapoff
    echo ""

    # Step 2: sleep with countdown
    if [[ $sleep_sec -gt 0 ]]; then
        log_info "[2/3] Waiting ${sleep_sec}s before re-enabling swap..."
        local remaining=$sleep_sec
        while [[ $remaining -gt 0 ]]; do
            printf "\r  Resuming in %3d seconds..." "$remaining"
            sleep 1
            remaining=$((remaining - 1))
        done
        echo ""
    else
        log_info "[2/3] Sleep skipped (0s)."
    fi
    echo ""

    # Step 3: swapon
    log_info "[3/3] Re-enabling swap..."
    do_swapon
    echo ""

    log_info "=== Flush complete ==="
    show_status
}

# --- Usage ---
usage() {
    cat <<EOF
Usage: sudo $0 <command> [options]

Commands:
  off              Safely disable swap (with memory checks)
  on               Enable swap
  status           Show current memory/swap status
  flush [options]  Disable swap, wait, then re-enable (clears swap)

Flush options:
  --sleep <sec>    Sleep duration between off and on (default: ${DEFAULT_FLUSH_SLEEP}s)

Examples:
  sudo $0 off
  sudo $0 on
  sudo $0 flush
  sudo $0 flush --sleep 30

Config (edit in script):
  SAFETY_RATIO=${SAFETY_RATIO}  (max swap_used/available % before aborting)
EOF
    exit 1
}

# --- Parse flush args ---
parse_flush_args() {
    local sleep_sec="$DEFAULT_FLUSH_SLEEP"
    shift  # consume "flush"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --sleep|-s)
                sleep_sec="${2:?'--sleep requires a value'}"
                shift 2
                ;;
            *)
                log_error "Unknown option: $1"
                usage
                ;;
        esac
    done
    echo "$sleep_sec"
}

# --- Main ---
check_root

case "${1:-}" in
    off)    do_swapoff ;;
    on)     do_swapon  ;;
    status) show_status ;;
    flush)
        sleep_sec=$(parse_flush_args "$@")
        do_flush "$sleep_sec"
        ;;
    *)      usage ;;
esac
